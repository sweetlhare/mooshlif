data/
# артефакты
reports/
runs/
*.pt
*.pth
*.onnx
# лёгкие sklearn-модели версионируем, тяжёлые веса — через релизы/архив
!models/*.pkl
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
.venv/
*.egg-info/
dist/
build/
# кэши признаков и превью
*.parquet
